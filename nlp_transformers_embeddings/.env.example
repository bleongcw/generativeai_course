# Copy this file to `.env` before running live API examples.
# Never commit `.env`; it contains credentials, not course content.

# Required for OpenAI examples: embeddings, generation, structured outputs, and evaluation.
OPENAI_API_KEY=your_openai_api_key_here

# Required for Anthropic examples: Claude generation, query rewriting, synthesis, and evaluation.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional future-provider keys. Keep these blank until the relevant notebook needs them.
GOOGLE_API_KEY=your_google_ai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here

# Classroom safety switch. Set to false only when you intentionally want live API calls.
LIVE_API=false
